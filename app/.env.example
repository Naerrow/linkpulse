# linkpulse 로컬 설정 예시.
# 실제 값은 .env 파일에 두며 커밋하지 않는다(.gitignore 처리됨).
# 비밀값(운영 DB 비밀번호·토큰 등)은 절대 여기에 넣지 않는다.

# 애플리케이션 리슨 포트
APP_PORT=8080

# Postgres 접속 문자열 (로컬 docker-compose 기준의 더미 자격증명)
DATABASE_URL=postgres://linkpulse:linkpulse@localhost:5432/linkpulse?sslmode=disable

# 단축 URL을 만들 때 앞에 붙일 공개 베이스 URL (예: https://lpx.dev)
PUBLIC_BASE_URL=http://localhost:8080

# 단축 코드 길이(base62 문자 수)
SHORT_CODE_LENGTH=7

# 로그 레벨: debug | info | warn | error
LOG_LEVEL=info
