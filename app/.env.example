# linkpulse 로컬 설정 예시.
# 실제 값은 .env 파일에 두며 커밋하지 않는다(.gitignore 처리됨).
# 비밀값(운영 DB 비밀번호·토큰 등)은 절대 여기에 넣지 않는다.

# 애플리케이션 리슨 포트
APP_PORT=8080

# Postgres 접속 문자열 (로컬 docker-compose 기준의 더미 자격증명)
DATABASE_URL=postgres://linkpulse:linkpulse@localhost:5432/linkpulse?sslmode=disable

# 단축 URL을 만들 때 앞에 붙일 공개 베이스 URL (예: https://lpx.dev)
PUBLIC_BASE_URL=http://localhost:8080

# 단축 코드 길이(base62 문자 수)
SHORT_CODE_LENGTH=7

# 로그 레벨: debug | info | warn | error
LOG_LEVEL=info

# 실행 환경: development | production (미설정=development).
# 로컬은 미설정으로 두면 DB 없이 인메모리로 뜬다. 운영(ECS)에서만 production으로 설정하며,
# 이때 DB(DATABASE_URL 또는 DB_*)가 없으면 기동을 중단한다(데이터 유실 방지).
# APP_ENV=development

# --- 운영(ECS) 전용: 비밀번호 분리 주입 ---
# 운영에서는 DATABASE_URL 대신 아래 DB_* 를 쓴다. DB_PASSWORD만 Secrets Manager에서
# 주입하고 나머지는 평문 env로 둔다(가드레일 #2). DATABASE_URL이 설정돼 있으면 그쪽이
# 우선하므로, 로컬은 위 DATABASE_URL 한 줄이면 충분하다.
# DB_HOST=<rds-endpoint>.ap-northeast-2.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=linkpulse
# DB_USER=linkpulse
# DB_PASSWORD=<Secrets Manager 주입 — 절대 커밋 금지>
# DB_SSLMODE=require
