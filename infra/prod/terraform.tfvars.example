# `terraform.tfvars`로 복사해 환경값을 채운다(실제 tfvars는 .gitignore). 비밀값은 넣지 않는다.

# 도메인(이미 Route53에 있는 호스팅 영역).
domain_name = "lpulse.live"
# hosted_zone_id = "Z0123456789ABCDEFGHIJ"  # 동일 이름 zone이 여러 개일 때만 지정

# 운영 중 안전 기본값: 태스크 2개(무인자 apply가 prod를 0으로 떨구지 않게).
# 단 최초 부트스트랩(이미지가 ECR에 없음)에는 그대로 apply하지 말고 -var service_desired_count=0으로
# 인프라를 먼저 만든다(README "배포 순서" 참고).
service_desired_count = 2
# 부트스트랩 placeholder. 가동 후 운영 이미지는 CI(P2)가 git sha로 배포하므로,
# 수동 apply 시에는 현재 라이브 태그(예: v1)로 맞춘다.
image_tag = "bootstrap"

# 비용/사양 조정 예시(기본값으로도 동작).
# db_instance_class = "db.t4g.micro"
# task_cpu          = "256"
# task_memory       = "512"

# GitHub OIDC 공급자가 계정에 이미 있으면(다른 프로젝트 등) 그 ARN을 지정한다(없으면 비워둠 → 새로 생성).
# apply 전 `aws iam list-open-id-connect-providers`로 확인.
# existing_github_oidc_provider_arn = "arn:aws:iam::<ACCOUNT_ID>:oidc-provider/token.actions.githubusercontent.com"

# ---- 모니터링 / Slack 알림 (P3) ----
# Container Insights는 default true(P3). 끄려면 아래 주석을 해제한다(비용 소폭↓, 태스크 레벨 메트릭 상실).
# enable_container_insights = false
#
# Slack 통지: AWS 콘솔 "Amazon Q Developer in chat applications"에서 workspace를 OAuth 승인한 뒤
# team/channel ID를 넣는다(둘 다 필수 — 한쪽만 넣으면 apply 전 validation 에러). 채널 ID는 채널명이 아니라
# 우클릭→링크 복사 끝의 문자열(예: C0123ABCDEF). 승인 후 Slack 채널에서 `/invite @Amazon Q` 실행 필요.
# 준비 전이면 둘 다 비워 알람+SNS만 먼저 apply한다(Slack 배선 스킵).
# slack_team_id    = "T0123ABCD"
# slack_channel_id = "C0123ABCDEF"
